{
  "name": "closeby",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"pnpm --filter @closeby/web dev\" \"pnpm --filter @closeby/api dev\"",
    "build": "pnpm --filter @closeby/shared build && pnpm --filter @closeby/db build && pnpm --filter @closeby/api build && pnpm --filter @closeby/web build",
    "start": "pnpm --filter @closeby/api start"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
